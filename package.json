    "histoire": "^0.17.9",
    "npm-run-all": "^4.1.5",
    "svelte-check": "^3.6.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "dependencies": {
    "@arl/leaflet-tracksymbol2": "link:../leaflet-tracksymbol2",
